# MiniClaw 环境变量配置
# 复制为 .env 并填入你的配置：cp .env.example .env

# LLM 配置（所有 OpenAI 兼容平台通用）
# 切换平台/模型只改这三行，无需修改 config.yaml
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat

# 如果不同角色使用不同平台/模型，可以配置多组
# LLM_BASE_URL_2=https://api.openai.com/v1
# LLM_API_KEY_2=sk-your-second-key-here
# LLM_MODEL_2=gpt-4o
